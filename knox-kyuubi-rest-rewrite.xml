<rules>
    <!-- Inbound URL rewrite rules for Kyuubi REST API -->
    
    <!-- API v1 endpoints -->
    <rule dir="IN" name="KYUUBI_REST/kyuubi-rest/inbound/api/v1" pattern="*://*:*/**/kyuubi/api/v1/{path=**}?{**}">
        <rewrite template="{$serviceUrl[KYUUBI_REST]}/api/v1/{path=**}?{**}"/>
    </rule>
    
    <!-- Batch operations -->
    <rule dir="IN" name="KYUUBI_REST/kyuubi-rest/inbound/batches" pattern="*://*:*/**/kyuubi/api/v1/batches?{**}">
        <rewrite template="{$serviceUrl[KYUUBI_REST]}/api/v1/batches?{**}"/>
    </rule>
    
    <rule dir="IN" name="KYUUBI_REST/kyuubi-rest/inbound/batches/path" pattern="*://*:*/**/kyuubi/api/v1/batches/{path=**}?{**}">
        <rewrite template="{$serviceUrl[KYUUBI_REST]}/api/v1/batches/{path=**}?{**}"/>
    </rule>
    
    <!-- Sessions -->
    <rule dir="IN" name="KYUUBI_REST/kyuubi-rest/inbound/sessions" pattern="*://*:*/**/kyuubi/api/v1/sessions?{**}">
        <rewrite template="{$serviceUrl[KYUUBI_REST]}/api/v1/sessions?{**}"/>
    </rule>
    
    <rule dir="IN" name="KYUUBI_REST/kyuubi-rest/inbound/sessions/path" pattern="*://*:*/**/kyuubi/api/v1/sessions/{path=**}?{**}">
        <rewrite template="{$serviceUrl[KYUUBI_REST]}/api/v1/sessions/{path=**}?{**}"/>
    </rule>
    
    <!-- Operations -->
    <rule dir="IN" name="KYUUBI_REST/kyuubi-rest/inbound/operations" pattern="*://*:*/**/kyuubi/api/v1/operations?{**}">
        <rewrite template="{$serviceUrl[KYUUBI_REST]}/api/v1/operations?{**}"/>
    </rule>
    
    <rule dir="IN" name="KYUUBI_REST/kyuubi-rest/inbound/operations/path" pattern="*://*:*/**/kyuubi/api/v1/operations/{path=**}?{**}">
        <rewrite template="{$serviceUrl[KYUUBI_REST]}/api/v1/operations/{path=**}?{**}"/>
    </rule>
    
    <!-- Server info and health -->
    <rule dir="IN" name="KYUUBI_REST/kyuubi-rest/inbound/info" pattern="*://*:*/**/kyuubi/api/v1/info?{**}">
        <rewrite template="{$serviceUrl[KYUUBI_REST]}/api/v1/info?{**}"/>
    </rule>
    
    <rule dir="IN" name="KYUUBI_REST/kyuubi-rest/inbound/ping" pattern="*://*:*/**/kyuubi/api/v1/ping?{**}">
        <rewrite template="{$serviceUrl[KYUUBI_REST]}/api/v1/ping?{**}"/>
    </rule>
    
    <!-- Admin endpoints -->
    <rule dir="IN" name="KYUUBI_REST/kyuubi-rest/inbound/admin" pattern="*://*:*/**/kyuubi/api/v1/admin/{path=**}?{**}">
        <rewrite template="{$serviceUrl[KYUUBI_REST]}/api/v1/admin/{path=**}?{**}"/>
    </rule>
    
    <!-- Outbound URL rewrite rules for JSON responses -->
    
    <!-- Rewrite URLs in JSON responses -->
    <rule dir="OUT" name="KYUUBI_REST/kyuubi-rest/outbound/json/url" pattern="/api/v1/{path=**}">
        <rewrite template="{$frontend[path]}/kyuubi/api/v1/{path=**}"/>
    </rule>
    
    <!-- Rewrite batch URLs -->
    <rule dir="OUT" name="KYUUBI_REST/kyuubi-rest/outbound/json/batch" pattern="/api/v1/batches/{id}">
        <rewrite template="{$frontend[path]}/kyuubi/api/v1/batches/{id}"/>
    </rule>
    
    <!-- Rewrite session URLs -->
    <rule dir="OUT" name="KYUUBI_REST/kyuubi-rest/outbound/json/session" pattern="/api/v1/sessions/{id}">
        <rewrite template="{$frontend[path]}/kyuubi/api/v1/sessions/{id}"/>
    </rule>
    
    <!-- Rewrite operation URLs -->
    <rule dir="OUT" name="KYUUBI_REST/kyuubi-rest/outbound/json/operation" pattern="/api/v1/operations/{id}">
        <rewrite template="{$frontend[path]}/kyuubi/api/v1/operations/{id}"/>
    </rule>
    
    <!-- JSON content filters -->
    <filter name="KYUUBI_REST/kyuubi-rest/outbound/json">
        <content type="application/json">
            <!-- Rewrite URLs in JSON responses -->
            <apply path="$.url" rule="KYUUBI_REST/kyuubi-rest/outbound/json/url"/>
            <apply path="$.*.url" rule="KYUUBI_REST/kyuubi-rest/outbound/json/url"/>
            <apply path="$.**.url" rule="KYUUBI_REST/kyuubi-rest/outbound/json/url"/>
            
            <!-- Rewrite batch-specific URLs -->
            <apply path="$.batchId" rule="KYUUBI_REST/kyuubi-rest/outbound/json/batch"/>
            <apply path="$.*.batchId" rule="KYUUBI_REST/kyuubi-rest/outbound/json/batch"/>
            
            <!-- Rewrite session-specific URLs -->
            <apply path="$.sessionId" rule="KYUUBI_REST/kyuubi-rest/outbound/json/session"/>
            <apply path="$.*.sessionId" rule="KYUUBI_REST/kyuubi-rest/outbound/json/session"/>
            
            <!-- Rewrite operation-specific URLs -->
            <apply path="$.operationId" rule="KYUUBI_REST/kyuubi-rest/outbound/json/operation"/>
            <apply path="$.*.operationId" rule="KYUUBI_REST/kyuubi-rest/outbound/json/operation"/>
        </content>
    </filter>
    
    <!-- Headers filter -->
    <filter name="KYUUBI_REST/kyuubi-rest/outbound/headers">
        <content type="application/x-http-headers">
            <apply path="Location" rule="KYUUBI_REST/kyuubi-rest/outbound/json/url"/>
        </content>
    </filter>
</rules>