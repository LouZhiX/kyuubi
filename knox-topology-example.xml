<topology>
    <!-- Gateway providers configuration -->
    <gateway>
        <!-- Authentication provider -->
        <provider>
            <role>authentication</role>
            <name>ShiroProvider</name>
            <enabled>true</enabled>
            <param>
                <name>sessionTimeout</name>
                <value>30</value>
            </param>
            <param>
                <name>main.ldapRealm</name>
                <value>org.apache.hadoop.gateway.shirorealm.KnoxLdapRealm</value>
            </param>
            <param>
                <name>main.ldapContextFactory</name>
                <value>org.apache.hadoop.gateway.shirorealm.KnoxLdapContextFactory</value>
            </param>
            <param>
                <name>main.ldapRealm.contextFactory</name>
                <value>$ldapContextFactory</value>
            </param>
            <param>
                <name>main.ldapContextFactory.url</name>
                <value>ldap://localhost:33389</value>
            </param>
            <param>
                <name>main.ldapContextFactory.userDnTemplate</name>
                <value>uid={0},ou=people,dc=hadoop,dc=apache,dc=org</value>
            </param>
            <param>
                <name>main.ldapContextFactory.authenticationMechanism</name>
                <value>simple</value>
            </param>
            <param>
                <name>urls./**</name>
                <value>authcBasic</value>
            </param>
        </provider>

        <!-- Identity assertion provider -->
        <provider>
            <role>identity-assertion</role>
            <name>Default</name>
            <enabled>true</enabled>
        </provider>

        <!-- Authorization provider -->
        <provider>
            <role>authorization</role>
            <name>AclsAuthz</name>
            <enabled>true</enabled>
        </provider>

        <!-- Host mapping provider -->
        <provider>
            <role>hostmap</role>
            <name>static</name>
            <enabled>true</enabled>
            <param>
                <name>localhost</name>
                <value>sandbox.hortonworks.com</value>
            </param>
        </provider>
    </gateway>

    <!-- Service definitions -->
    
    <!-- Kyuubi WebUI Service -->
    <service>
        <role>KYUUBI</role>
        <url>http://kyuubi-server-host:10099</url>
        <!-- 
        Note: 
        - Replace 'kyuubi-server-host' with your actual Kyuubi server hostname
        - Port 10099 is the default REST API port for Kyuubi
        - If you're using HTTPS, change the URL scheme to https
        -->
    </service>

    <!-- Optional: Other Hadoop services that might be used with Kyuubi -->
    
    <!-- HDFS WebHDFS -->
    <service>
        <role>WEBHDFS</role>
        <url>http://namenode-host:9870/webhdfs</url>
    </service>

    <!-- Spark History Server (if using Spark with Kyuubi) -->
    <service>
        <role>SPARKHISTORYUI</role>
        <url>http://spark-history-server-host:18080</url>
    </service>

    <!-- YARN Resource Manager -->
    <service>
        <role>RESOURCEMANAGER</role>
        <url>http://resourcemanager-host:8088/ws</url>
    </service>

    <!-- Hive Server2 (if using alongside Kyuubi) -->
    <service>
        <role>HIVE</role>
        <url>http://hiveserver2-host:10001/cliservice</url>
    </service>

    <!-- Livy Server (if using Livy with Kyuubi) -->
    <service>
        <role>LIVY</role>
        <url>http://livy-server-host:8998</url>
    </service>
</topology>