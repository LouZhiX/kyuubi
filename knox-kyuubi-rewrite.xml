<rules>
    <!-- Inbound URL rewrite rules -->
    
    <!-- Root path rewrite -->
    <rule dir="IN" name="KYUUBI/kyuubi/inbound/root" pattern="*://*:*/**/kyuubi">
        <rewrite template="{$serviceUrl[KYUUBI]}/"/>
    </rule>
    
    <!-- Root path with trailing slash -->
    <rule dir="IN" name="KYUUBI/kyuubi/inbound/root/slash" pattern="*://*:*/**/kyuubi/">
        <rewrite template="{$serviceUrl[KYUUBI]}/"/>
    </rule>
    
    <!-- General path rewrite for all sub-paths -->
    <rule dir="IN" name="KYUUBI/kyuubi/inbound/path" pattern="*://*:*/**/kyuubi/{path=**}?{**}">
        <rewrite template="{$serviceUrl[KYUUBI]}/{path=**}?{**}"/>
    </rule>
    
    <!-- Outbound URL rewrite rules for response content -->
    
    <!-- Base URL rewrite rule -->
    <rule dir="OUT" name="KYUUBI/kyuubi/outbound/base" pattern="{scheme}://{host}:{port}">
        <rewrite template="{$frontend[scheme]}://{$frontend[host]}:{$frontend[port]}{$frontend[path]}/kyuubi"/>
    </rule>
    
    <!-- Static assets rewrite -->
    <rule dir="OUT" name="KYUUBI/kyuubi/outbound/assets" pattern="/assets/{**}">
        <rewrite template="{$frontend[path]}/kyuubi/assets/{**}"/>
    </rule>
    
    <rule dir="OUT" name="KYUUBI/kyuubi/outbound/static" pattern="/static/{**}">
        <rewrite template="{$frontend[path]}/kyuubi/static/{**}"/>
    </rule>
    
    <rule dir="OUT" name="KYUUBI/kyuubi/outbound/js" pattern="/js/{**}">
        <rewrite template="{$frontend[path]}/kyuubi/js/{**}"/>
    </rule>
    
    <rule dir="OUT" name="KYUUBI/kyuubi/outbound/css" pattern="/css/{**}">
        <rewrite template="{$frontend[path]}/kyuubi/css/{**}"/>
    </rule>
    
    <rule dir="OUT" name="KYUUBI/kyuubi/outbound/images" pattern="/images/{**}">
        <rewrite template="{$frontend[path]}/kyuubi/images/{**}"/>
    </rule>
    
    <rule dir="OUT" name="KYUUBI/kyuubi/outbound/fonts" pattern="/fonts/{**}">
        <rewrite template="{$frontend[path]}/kyuubi/fonts/{**}"/>
    </rule>
    
    <!-- API endpoints rewrite -->
    <rule dir="OUT" name="KYUUBI/kyuubi/outbound/api" pattern="/api/{**}">
        <rewrite template="{$frontend[path]}/kyuubi/api/{**}"/>
    </rule>
    
    <!-- Common web resources -->
    <rule dir="OUT" name="KYUUBI/kyuubi/outbound/favicon" pattern="/favicon.ico">
        <rewrite template="{$frontend[path]}/kyuubi/favicon.ico"/>
    </rule>
    
    <rule dir="OUT" name="KYUUBI/kyuubi/outbound/manifest" pattern="/manifest.json">
        <rewrite template="{$frontend[path]}/kyuubi/manifest.json"/>
    </rule>
    
    <!-- Relative path rewrite for common patterns -->
    <rule dir="OUT" name="KYUUBI/kyuubi/outbound/relative/assets" pattern="assets/{**}">
        <rewrite template="{$frontend[path]}/kyuubi/assets/{**}"/>
    </rule>
    
    <rule dir="OUT" name="KYUUBI/kyuubi/outbound/relative/static" pattern="static/{**}">
        <rewrite template="{$frontend[path]}/kyuubi/static/{**}"/>
    </rule>
    
    <rule dir="OUT" name="KYUUBI/kyuubi/outbound/relative/js" pattern="js/{**}">
        <rewrite template="{$frontend[path]}/kyuubi/js/{**}"/>
    </rule>
    
    <rule dir="OUT" name="KYUUBI/kyuubi/outbound/relative/css" pattern="css/{**}">
        <rewrite template="{$frontend[path]}/kyuubi/css/{**}"/>
    </rule>
    
    <!-- Filters for different content types -->
    
    <!-- HTML content filter -->
    <filter name="KYUUBI/kyuubi/outbound/html">
        <content type="text/html">
            <apply path="href" rule="KYUUBI/kyuubi/outbound/assets"/>
            <apply path="src" rule="KYUUBI/kyuubi/outbound/assets"/>
            <apply path="href" rule="KYUUBI/kyuubi/outbound/static"/>
            <apply path="src" rule="KYUUBI/kyuubi/outbound/static"/>
            <apply path="href" rule="KYUUBI/kyuubi/outbound/js"/>
            <apply path="src" rule="KYUUBI/kyuubi/outbound/js"/>
            <apply path="href" rule="KYUUBI/kyuubi/outbound/css"/>
            <apply path="src" rule="KYUUBI/kyuubi/outbound/css"/>
            <apply path="href" rule="KYUUBI/kyuubi/outbound/images"/>
            <apply path="src" rule="KYUUBI/kyuubi/outbound/images"/>
            <apply path="href" rule="KYUUBI/kyuubi/outbound/fonts"/>
            <apply path="src" rule="KYUUBI/kyuubi/outbound/fonts"/>
            <apply path="href" rule="KYUUBI/kyuubi/outbound/api"/>
            <apply path="src" rule="KYUUBI/kyuubi/outbound/api"/>
            <apply path="href" rule="KYUUBI/kyuubi/outbound/favicon"/>
            <apply path="src" rule="KYUUBI/kyuubi/outbound/favicon"/>
            <apply path="href" rule="KYUUBI/kyuubi/outbound/manifest"/>
            <apply path="src" rule="KYUUBI/kyuubi/outbound/manifest"/>
            <!-- Relative paths -->
            <apply path="href" rule="KYUUBI/kyuubi/outbound/relative/assets"/>
            <apply path="src" rule="KYUUBI/kyuubi/outbound/relative/assets"/>
            <apply path="href" rule="KYUUBI/kyuubi/outbound/relative/static"/>
            <apply path="src" rule="KYUUBI/kyuubi/outbound/relative/static"/>
            <apply path="href" rule="KYUUBI/kyuubi/outbound/relative/js"/>
            <apply path="src" rule="KYUUBI/kyuubi/outbound/relative/js"/>
            <apply path="href" rule="KYUUBI/kyuubi/outbound/relative/css"/>
            <apply path="src" rule="KYUUBI/kyuubi/outbound/relative/css"/>
        </content>
    </filter>
    
    <!-- CSS content filter -->
    <filter name="KYUUBI/kyuubi/outbound/css">
        <content type="text/css">
            <apply path="url" rule="KYUUBI/kyuubi/outbound/assets"/>
            <apply path="url" rule="KYUUBI/kyuubi/outbound/static"/>
            <apply path="url" rule="KYUUBI/kyuubi/outbound/images"/>
            <apply path="url" rule="KYUUBI/kyuubi/outbound/fonts"/>
            <apply path="url" rule="KYUUBI/kyuubi/outbound/relative/assets"/>
            <apply path="url" rule="KYUUBI/kyuubi/outbound/relative/static"/>
            <apply path="url" rule="KYUUBI/kyuubi/outbound/relative/images"/>
            <apply path="url" rule="KYUUBI/kyuubi/outbound/relative/fonts"/>
        </content>
    </filter>
    
    <!-- JavaScript content filter -->
    <filter name="KYUUBI/kyuubi/outbound/javascript">
        <content type="application/javascript">
            <apply path="$" rule="KYUUBI/kyuubi/outbound/base"/>
            <apply path="$" rule="KYUUBI/kyuubi/outbound/api"/>
            <apply path="$" rule="KYUUBI/kyuubi/outbound/assets"/>
            <apply path="$" rule="KYUUBI/kyuubi/outbound/static"/>
        </content>
    </filter>
    
    <!-- JSON content filter for API responses -->
    <filter name="KYUUBI/kyuubi/outbound/json">
        <content type="application/json">
            <apply path="$.url" rule="KYUUBI/kyuubi/outbound/base"/>
            <apply path="$.*.url" rule="KYUUBI/kyuubi/outbound/base"/>
            <apply path="$.**.url" rule="KYUUBI/kyuubi/outbound/base"/>
        </content>
    </filter>
    
    <!-- Headers filter to handle CORS and other headers -->
    <filter name="KYUUBI/kyuubi/outbound/headers">
        <content type="application/x-http-headers">
            <apply path="Location" rule="KYUUBI/kyuubi/outbound/base"/>
        </content>
    </filter>
</rules>