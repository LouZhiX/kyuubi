<!--
  This is the Knox service definition for Apache Kyuubi WebUI.
  This file should be placed in the Knox gateway's data/services directory.
  
  Service name: KYUUBI
  Version: 1.9.0
  
  This service definition enables Knox to proxy requests to Kyuubi WebUI
  and provides proper URL rewriting and header forwarding.
-->

<service role="KYUUBI" name="kyuubi" version="1.9.0">
    
    <!-- Kyuubi WebUI main interface -->
    <routes>
        <!-- Main WebUI route -->
        <route path="/kyuubi/ui/**">
            <rewrite apply="KYUUBI/kyuubi/inbound" to="request.url"/>
        </route>
        
        <!-- API routes for WebUI functionality -->
        <route path="/kyuubi/api/**">
            <rewrite apply="KYUUBI/kyuubi/inbound" to="request.url"/>
        </route>
        
        <!-- Static resources (CSS, JS, images) -->
        <route path="/kyuubi/static/**">
            <rewrite apply="KYUUBI/kyuubi/inbound" to="request.url"/>
        </route>
        
        <!-- Health check endpoint -->
        <route path="/kyuubi/health">
            <rewrite apply="KYUUBI/kyuubi/inbound" to="request.url"/>
        </route>
        
        <!-- Service info endpoint -->
        <route path="/kyuubi/service-info">
            <rewrite apply="KYUUBI/kyuubi/inbound" to="request.url"/>
        </route>
        
        <!-- WebSocket connections for real-time updates -->
        <route path="/kyuubi/ws/**">
            <rewrite apply="KYUUBI/kyuubi/inbound" to="request.url"/>
        </route>
        
        <!-- REST API endpoints -->
        <route path="/kyuubi/v1/**">
            <rewrite apply="KYUUBI/kyuubi/inbound" to="request.url"/>
        </route>
    </routes>
    
    <!-- URL rewrite rules -->
    <rewrite-rules>
        <!-- Inbound rewrite rules (Gateway -> Kyuubi) -->
        <rule dir="IN" name="KYUUBI/kyuubi/inbound" pattern="*://*:*/**/kyuubi/{path=**}?{**}">
            <rewrite template="{$serviceUrl[KYUUBI]}/{path=**}?{**}"/>
        </rule>
        
        <!-- Outbound rewrite rules (Kyuubi -> Gateway) -->
        <rule dir="OUT" name="KYUUBI/kyuubi/outbound" pattern="{$serviceUrl[KYUUBI]}/{path=**}?{**}">
            <rewrite template="{$frontend[url]}/gateway/{$gateway[name]}/kyuubi/{path=**}?{**}"/>
        </rule>
        
        <!-- Handle redirects from Kyuubi -->
        <rule dir="OUT" name="KYUUBI/kyuubi/redirect" pattern="http://{host}:{port}/{path=**}">
            <rewrite template="{$frontend[url]}/gateway/{$gateway[name]}/kyuubi/{path=**}"/>
        </rule>
        
        <!-- Handle Location headers -->
        <rule dir="OUT" name="KYUUBI/kyuubi/location" pattern="Location: http://{host}:{port}/{path=**}">
            <rewrite template="Location: {$frontend[url]}/gateway/{$gateway[name]}/kyuubi/{path=**}"/>
        </rule>
    </rewrite-rules>
    
    <!-- Dispatch rules for load balancing and failover -->
    <dispatch classname="org.apache.knox.gateway.dispatch.DefaultDispatch" 
              ha-classname="org.apache.knox.gateway.ha.dispatch.DefaultHaDispatch"
              use-two-way-ssl="false">
        <!-- Custom headers to be added to requests -->
        <param name="httpclient.connectionTimeout" value="5000"/>
        <param name="httpclient.socketTimeout" value="60000"/>
    </dispatch>
    
</service>